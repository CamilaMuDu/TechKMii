<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
	 <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
   <section name="TechKMii.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
  </sectionGroup>
 </configSections>
	<appSettings>
		<add key="NombreEmpresa" value="UTN Company." />
		<add key="URLPadron" value="https://api.hacienda.go.cr/fe/ae?identificacion=" />
		<add key="URLProvincia" value="https://raw.githubusercontent.com/lateraluz/Datos/refs/heads/master/provincias.json" />
	</appSettings>
    <connectionStrings>
        <add name="default" connectionString="Data Source=DESKTOP-SB0IICF;Initial Catalog=BD_TechKMii;Persist Security Info=True;User ID=sa;Password=123456;TrustServerCertificate=True"
            providerName="System.Data.SqlClient" />
        <add name="TechKMii.Properties.Settings.BD_TechKMii" connectionString="Data Source=DESKTOP-SB0IICF;Initial Catalog=BD_TechKMii;Persist Security Info=True;User ID=sa;Password=123456;TrustServerCertificate=True"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
	<startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
	<log4net>
		<root>
			<level value="ALL" />
			<appender-ref ref="MyControlEventos" />
		</root>
		<appender name="MyControlEventos" type="log4net.Appender.FileAppender">
			<file type="log4net.Util.PatternString"
        value="c:\temp\Eventos-%date{yyyy-MM-dd}.txt" />
			<appendToFile value="true" />
			<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="%date %level -%message%newline" />
			</layout>
		</appender>
	</log4net>
 <userSettings>
  <TechKMii.Properties.Settings>
   <setting name="Usuario" serializeAs="String">
    <value>0</value>
   </setting>
   <setting name="Nombre" serializeAs="String">
    <value />
   </setting>
   <setting name="Rol" serializeAs="String">
    <value />
   </setting>	  

  </TechKMii.Properties.Settings>
 </userSettings>
 <system.serviceModel>
  <bindings>
   <basicHttpBinding>
    <binding name="wsindicadoreseconomicosSoap">
     <security mode="Transport" />
    </binding>
    <binding name="wsindicadoreseconomicosSoap1" />
   </basicHttpBinding>
   <customBinding>
    <binding name="wsindicadoreseconomicosSoap12">
     <textMessageEncoding messageVersion="Soap12" />
     <httpsTransport />
    </binding>
   </customBinding>
  </bindings>
  <client>
   <endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx"
    binding="basicHttpBinding" bindingConfiguration="wsindicadoreseconomicosSoap"
    contract="ServicioBCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap" />
   <endpoint address="https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx"
    binding="customBinding" bindingConfiguration="wsindicadoreseconomicosSoap12"
    contract="ServicioBCCR.wsindicadoreseconomicosSoap" name="wsindicadoreseconomicosSoap12" />
  </client>
 </system.serviceModel>
</configuration>